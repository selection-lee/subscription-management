{
  "name": "subscription-management",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "app": "pnpm --filter @lib/app dev",
    "api": "pnpm --filter @lib/api dev",
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "clean": "pnpm -r run clean",
    "reset": "pnpm clean && pnpm install && pnpm --filter @lib/schema run db:generate && pnpm build"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "eslint": "catalog:",
    "@eslint/js": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
